{
  "name": "@odysseon/auth",
  "version": "1.0.0",
  "description": "Identity-only authentication module for NestJS — hexagonal architecture, ORM-agnostic",
  "author": "Odysseon",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prebuild": "pnpm clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/jest-e2e.json --no-coverage",
    "ci:check": "pnpm typecheck && pnpm lint:check && pnpm format:check && pnpm test && pnpm test:e2e",
    "prepack": "pnpm build",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/passport": "^10.0.0 || ^11.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "argon2": {
      "optional": true
    },
    "passport-google-oauth20": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "argon2": "^0.44.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "argon2": "^0.44.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.0.0",
    "lint-staged": "^15.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.2",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/index.ts",
      "!**/*.interface.ts",
      "!**/interfaces/ports/**",
      "!**/core/auth.module.ts",
      "!**/decorators/**",
      "!**/guards/google-oauth.guard.ts",
      "!**/*.spec.ts"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testEnvironment": "node",
    "coverageReporters": [
      "text",
      "lcov",
      "text-summary"
    ],
    "setupFiles": [
      "reflect-metadata"
    ]
  },
  "keywords": [
    "nestjs",
    "auth",
    "authentication",
    "jwt",
    "passport",
    "google-oauth",
    "hexagonal",
    "ports-and-adapters",
    "identity",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/odysseon/auth.git"
  },
  "homepage": "https://github.com/odysseon/auth#readme",
  "bugs": {
    "url": "https://github.com/odysseon/auth/issues"
  }
}
